MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/neuracms
MONGODB_URI=

# Auth.js secret. If you still have only JWT_SECRET from the old project,
# the app can read it as a fallback, but AUTH_SECRET is preferred.
AUTH_SECRET=replace-with-a-long-random-secret
JWT_SECRET=
NEXTAUTH_URL=http://localhost:3000
PREVIEW_TOKEN=replace-with-a-separate-preview-token
CRON_SECRET=replace-with-a-cron-secret

# AI integrations are required only for the Generate with AI workflow.
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

NEXT_PUBLIC_APP_NAME=NeuraCMS
